generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum ContactStatus {
  new
  in_progress
  resolved
  spam
}

enum SubscriberStatus {
  active
  unsubscribed
  bounced
}

enum AppUserRole {
  customer
  admin
}

enum OrderStatus {
  pending_payment
  payment_submitted
  confirmed
  in_progress
  completed
  cancelled
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts Post[]
}

model Post {
  id           String    @id @default(cuid())
  slug         String    @unique
  title        String
  excerpt      String
  content      String
  category     String
  coverImage   String?
  isPublished  Boolean   @default(true)
  publishedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  authorId     String?

  author   User?      @relation(fields: [authorId], references: [id])
  comments Comment[]

  @@index([isPublished, publishedAt])
}

model Comment {
  id         String   @id @default(cuid())
  postId     String
  name       String
  email      String
  message    String
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, isApproved, createdAt])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  status    ContactStatus @default(new)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  status    SubscriberStatus @default(active)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
}

model Service {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  summary     String
  content     String
  priceFrom   Int?
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CaseStudy {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  category    String
  year        Int
  summary     String
  content     String
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ServiceReview {
  id        String   @id @default(cuid())
  name      String
  message   String
  rating    Int
  isApproved Boolean @default(false)
  userId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user AppUser? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([isApproved, createdAt])
}

model AppUser {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         AppUserRole @default(customer)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions AuthSession[]
  cartItems CartItem[]
  orders   Order[]
  reviews  ServiceReview[]
  ebookProgress EbookProgress[]
  affiliateProfile AffiliateProfile?
  savedItems SavedItem[]
}

model AuthSession {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model Product {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  category    String
  audience    String
  priceLkr    Int
  delivery    String
  features    String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cartItems   CartItem[]
  orderItems  OrderItem[]

  @@index([category, isActive])
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

model Order {
  id             String   @id @default(cuid())
  userId         String
  status         OrderStatus @default(payment_submitted)
  totalLkr       Int
  paymentMethod  String   @default("bank_transfer")
  paymentRef     String
  paymentSlipUrl String
  note           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user  AppUser   @relation(fields: [userId], references: [id], onDelete: Cascade)
  items OrderItem[]

  @@index([userId, status, createdAt])
}

model OrderItem {
  id         String @id @default(cuid())
  orderId    String
  productId  String
  productName String
  priceLkr   Int
  quantity   Int

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
}

model RateLimitBucket {
  key       String   @id
  count     Int      @default(0)
  resetAt   DateTime
  updatedAt DateTime @updatedAt

  @@index([resetAt])
}

model EbookProgress {
  id                String   @id @default(cuid())
  userId            String
  ebookSlug         String
  completedChapters String   @default("[]")
  isCompleted       Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ebookSlug])
  @@index([userId])
}

model AffiliateProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  referralCode     String   @unique
  totalClicks      Int      @default(0)
  successfulReferrals Int   @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions     ReferralTransaction[]
}

model SavedItem {
  id        String   @id @default(cuid())
  userId    String
  productSlug String
  createdAt DateTime @default(now())

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productSlug])
  @@index([userId])
}

model ReferralTransaction {
  id                 String   @id @default(cuid())
  affiliateProfileId String
  referredEmail      String   // The email of the person who bought
  packageName        String   // e.g. "Student Package"
  createdAt          DateTime @default(now())

  affiliateProfile   AffiliateProfile @relation(fields: [affiliateProfileId], references: [id], onDelete: Cascade)
  
  @@index([affiliateProfileId])
}
